# Copy this EXACTLY - these are development-only keys
NODE_ENV=development
PORT=5000

# MongoDB (we'll use local for now)
MONGODB_URI=mongodb://localhost:27017/secure-banking

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# JWT Secrets (TEMP - generate real ones later)
JWT_ACCESS_SECRET=dev_access_secret_CHANGE_THIS_IN_PRODUCTION_min_64_chars_1234567890
JWT_REFRESH_SECRET=dev_refresh_secret_CHANGE_THIS_IN_PRODUCTION_min_64_chars_0987654321

# Encryption Key (TEMP - generate real one later)
ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef

# Plaid - Mock mode for now
USE_MOCK_PLAID=true
PLAID_ENV=sandbox

# Frontend
FRONTEND_URL=http://localhost:3000
CORS_ORIGIN=http://localhost:3000

# Email - Skip for now
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587

# Features
ENABLE_2FA=false
ENABLE_EMAIL_VERIFICATION=false
ENABLE_AUDIT_LOGGING=true